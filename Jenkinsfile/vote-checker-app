pipeline {
    agent any

    environment {
        PYTHON_PATH = "C:\\Users\\Diwakara\\AppData\\Local\\Programs\\Python\\Python311\\python.exe"
        PORT = "5000"
    }

    stages {

        stage('Debug Environment') {
            steps {
                bat 'echo Running as:'
                bat 'whoami'
                bat 'echo PATH:'
                bat 'echo %PATH%'
            }
        }

        stage('Install Dependencies') {
            steps {
                bat """
                "%PYTHON_PATH%" --version
                "%PYTHON_PATH%" -m venv venv
                venv\\Scripts\\activate
                "%PYTHON_PATH%" -m pip install --upgrade pip
                pip install flask
                """
            }
        }

        stage('Kill Existing App (if any)') {
            steps {
                bat '''
                taskkill /F /IM python.exe || exit 0
                '''
            }
        }

        stage('Run Flask App') {
            steps {
                bat """
                venv\\Scripts\\activate
                start /B "%PYTHON_PATH%" app.py
                """
            }
        }

        stage('Verify Application') {
            steps {
                bat '''
                timeout /t 5
                curl http://localhost:5000 || echo App not reachable
                '''
            }
        }
    }

    post {
        success {
            echo "✅ Flask Vote Checker App is running successfully!"
        }
        failure {
            echo "❌ Pipeline failed! Check logs carefully."
        }
    }
}
