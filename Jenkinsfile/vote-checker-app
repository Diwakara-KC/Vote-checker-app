pipeline {
    agent any

    environment {
        PORT = "5000"
    }

    stages {

        stage('Install Dependencies') {
            steps {
                bat '''
                python -m venv venv
                venv\\Scripts\\activate
                pip install --upgrade pip
                pip install flask
                '''
            }
        }

        stage('Run Flask App') {
            steps {
                bat '''
                venv\\Scripts\\activate
                start /B python app.py
                '''
            }
        }

        stage('Check Application') {
            steps {
                bat '''
                timeout /t 5
                curl http://localhost:5000
                '''
            }
        }
    }

    post {
        success {
            echo "✅ App is running successfully!"
        }
        failure {
            echo "❌ Pipeline failed!"
        }
    }
}
